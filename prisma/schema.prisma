generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyDevotional {
  id                    String   @id @default(cuid())
  date                  String   @unique
  dailyFocusImage       String
  dailyFocus            String
  verseText             String
  verseReference        String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  dailyDeclarationImage String
}

model Flyer {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BiblePlan {
  id          String   @id @default(cuid())
  type        String
  periodKey   String
  title       String?
  imageUrl    String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, periodKey])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  description String
  image       String   @default("BookOpen")
  imageUrl    String?
  category    String?
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimony {
  id         String   @id @default(cuid())
  title      String
  content    String
  authorName String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Prayer {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String
  scripture   String
  text        String
  isActive    Boolean  @default(true)
  isPinned    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
